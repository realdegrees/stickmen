{
	"name": "stickmen",
	"version": "0.0.1",
	"description": "Animated stick figures that walk, climb, and explore your web pages",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:package": "svelte-kit sync && svelte-package -o dist",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"prepublishOnly": "bun run build:package"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.8",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/package": "^2.3.7",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"typescript": "^5.7.0",
		"vite": "^6.0.0"
	},
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/fasc/stickmen"
	},
	"keywords": [
		"svelte",
		"stickmen",
		"animation",
		"canvas",
		"stick-figure",
		"pathfinding"
	]
}
